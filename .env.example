# Copy this file to ".env" and fill in real values.
# These two are the only secrets you need to run locally.

# PostgreSQL connection string.
# Local example:   postgresql://postgres:postgres@localhost:5432/rinodesk
# Hosted (Neon/Supabase): paste the connection string they give you.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rinodesk

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional overrides (defaults shown; you usually don't need these) ---
# API_TARGET=http://localhost:8080   # where the frontend proxies /api to
# PORT and BASE_PATH are auto-defaulted (API 8080, web 20290, base "/")
